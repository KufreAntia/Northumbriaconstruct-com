{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "northumbriaconstruct.com" }],
      "destination": "https://www.northumbriaconstruct.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "northumbriaconstruct-com.vercel.app" }],
      "destination": "https://www.northumbriaconstruct.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
